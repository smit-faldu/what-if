# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Qwen3 TTS (optional overrides — defaults shown)
# Set TTS_ENABLED=false on CPU-only machines to skip audio generation.
# The pipeline will still save tts_script.txt for manual Colab use.
TTS_ENABLED=true
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
TTS_SPEAKER=Ryan
TTS_LANGUAGE=English
# TTS_INSTRUCT=your custom voice instruct prompt here

# Flux Image API (self-hosted Cloudflare Workers — flux-2-klein-4b)
# FLUX_API_URLS: comma-separated list of worker endpoints.
#   Requests are distributed round-robin across all workers.
#   To add more workers, append another URL to the comma-separated list.
# Set FLUX_ENABLED=false to skip image generation (flux_prompts are still saved in dialogs.md).
FLUX_API_TOKEN=your_flux_bearer_token_here
FLUX_API_URLS=https://your-worker-1.workers.dev,https://your-worker-2.workers.dev
FLUX_ENABLED=true
